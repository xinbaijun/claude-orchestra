#!/bin/bash
# board_refresh_timestamp — 管家刷新 session 在 board 上的「最后活跃」时间戳 + commit（5-28 落地）
#
# 替代「派 chore-runner 写 .prompts/refresh-X.md → tpush → chore-runner Edit + commit」的链路。
# 时间戳跑 date 拿真值，禁脑补。
#
# 用法：board_refresh_timestamp <session-name>
#
# 实现在 scripts/butler-helpers.sh，本文件仅做 source + dispatch。

set -e
source ${PROJECT_ROOT}/scripts/butler-helpers.sh
board_refresh_timestamp "$@"
