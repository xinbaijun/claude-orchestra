#!/bin/bash
# sshfs-check — ad-hoc sshfs 健康检测 CLI（5-28 落地）
#
# 用法：
#   sshfs-check                    检 ${PROJECT_ROOT}（默认）
#   sshfs-check /some/other/path   检任意挂载点
#   sshfs-check -h | --help        usage
#
# 退出码：0 健康 / 1 unhealthy
#
# 实现在 scripts/sshfs_healthy.sh，本文件仅做 source + dispatch。

set -e

if [ "${1:-}" = "-h" ] || [ "${1:-}" = "--help" ]; then
  cat <<EOF
用法：sshfs-check [path]
  sshfs-check                    检 ${PROJECT_ROOT}（默认）
  sshfs-check /some/other/path   检任意挂载点

退出码：0 = healthy / 1 = unhealthy
EOF
  exit 0
fi

source ${PROJECT_ROOT}/scripts/sshfs_healthy.sh
path="${1:-${PROJECT_ROOT}}"
if sshfs_healthy "$path"; then
  echo "✅ $path healthy"
  exit 0
else
  echo "❌ $path unhealthy"
  exit 1
fi
